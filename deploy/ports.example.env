# Global host port mapping for OpenLocalSearchParser.
# Copy to deploy/ports.env and adjust if local ports are already in use.
#
# Internal container ports stay fixed. Only host-side bindings change here.

OLSP_FRONTEND_HOST_PORT=18473
OLSP_BACKEND_HOST_PORT=52891
OLSP_QDRANT_HOST_PORT=36144
OLSP_MINIO_API_HOST_PORT=49280
OLSP_MINIO_CONSOLE_HOST_PORT=49281

# Used by the frontend API docs page in the browser.
VITE_BACKEND_HOST_PORT=52891

# Offline image tags used by deploy/docker-compose.offline.yml
OLSP_IMAGE_BACKEND=openlocalsearchparser/backend:offline
OLSP_IMAGE_WORKER=openlocalsearchparser/worker:offline
OLSP_IMAGE_FRONTEND=openlocalsearchparser/frontend:offline
